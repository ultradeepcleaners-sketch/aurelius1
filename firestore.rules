rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Certificates collection
    match /certificates/{certificateId} {
      allow read, write: if true;
    }

    // Products collection
    match /products/{productId} {
      allow read, write: if true;
    }
  }
}
